  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gun-flud/react_quiz/issues"
  },
  "homepage": "https://github.com/gun-flud/react_quiz#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}