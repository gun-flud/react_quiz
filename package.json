{
  "name": "react_quiz",
  "version": "1.0.0",
  "description": "A fullstack React and Fastify quiz application.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
